# ==========================================================================
#  MTG Commander Deckbuilder — repo is CODE ONLY.
#  Your collection, your decks, and all generated/runtime data stay local.
# ==========================================================================

# Your MTG collection + every generated/runtime file (owned-cards.json,
# fx.json, decks.json, game-changers.json, per-commander build folders, …).
# game-changers.json is auto-fetched on first run, so nothing here is needed.
/data/

# Built outputs (per-deck HTML reports + Moxfield .txt imports) and the
# generated front-door page. All regenerated by the engine in your workspace.
/decks/
/index.html

# Per-deck authored build scripts (one per commander you build).
# The reusable engine/handbuild.ps1 TEMPLATE is kept and committed.
engine/handbuild-*.ps1

# Internal dev history — not needed by users.
REVIEW.md

# Editor / OS / dev artifacts
/.claude/
*.bak
*.tmp
*.temp
*.stackdump
*~
.DS_Store
Thumbs.db
